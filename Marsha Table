<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VOTER ID Status</title>
    <!--[if mso]>
    <noscript>
        <xml>
            <o:OfficeDocumentSettings>
                <o:PixelsPerInch>96</o:PixelsPerInch>
            </o:OfficeDocumentSettings>
        </xml>
    </noscript>
    <![endif]-->
</head>
<body style="margin: 0; padding: 0; background-color: #f5f5f5; font-family: Arial, Helvetica, sans-serif;">
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f5f5f5;">
        <tr>
            <td align="center" style="padding: 30px 10px;">
                <!-- Main Container -->
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="650" style="max-width: 650px; background-color: #ffffff; border: 3px solid #ab0000; border-radius: 8px;">
                    <tr>
                        <td style="padding: 0;">
                            <!-- Clickable Link Wrapper -->
                            <a href="LINK HERE" style="text-decoration: none; color: inherit; display: block;">
                                
                                <!-- Header -->
                                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                                    <tr>
                                        <td style="background-color: #ab0000; padding: 25px 35px; text-align: center;">
                                            <h1 style="margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 22px; font-weight: bold; color: #ffffff; text-transform: uppercase; letter-spacing: 1px;">
                                                VOTER ID SUPPORT STATUS
                                            </h1>
                                        </td>
                                    </tr>
                                </table>

                                <!-- Main Content -->
                                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                                    <tr>
                                        <td style="padding: 25px 35px;">
                                            
                                            <!-- Alert Message -->
                                            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                                                <tr>
                                                    <td style="background-color: #fef2f2; border-left: 5px solid #ab0000; padding: 20px 30px; margin-bottom: 30px;">
                                                        <h2 style="margin: 0 0 10px 0; font-family: Arial, Helvetica, sans-serif; font-size: 18px; font-weight: bold; color: #ab0000;">
                                                            ${Recipient.FIRST_NAME}, your neighbors have taken a stand
                                                        </h2>
                                                        <p style="margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #7f1d1d; line-height: 1.4;">
                                                            See how your position compares to those around you
                                                        </p>
                                                    </td>
                                                </tr>
                                            </table>

                                            <!-- Data Table -->
                                            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="border-collapse: collapse; border: 2px solid #e5e7eb; margin: 20px 0;">
                                                
                                                <!-- Your Status Row -->
                                                <tr>
                                                    <td style="background-color: #fee2e2; padding: 18px 35px; border-bottom: 2px solid #fecaca; width: 60%;">
                                                        <h3 style="margin: 0 0 5px 0; font-family: Arial, Helvetica, sans-serif; font-size: 20px; font-weight: bold; color: #1f2937;">
                                                            ${Recipient.FIRST_NAME}
                                                        </h3>
                                                        <p style="margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #6b7280; font-style: italic;">
                                                            That's you!
                                                        </p>
                                                    </td>
                                                    <td style="background-color: #ab0000; padding: 18px 35px; border-bottom: 2px solid #fecaca; text-align: center; width: 40%;">
                                                        <span style="font-family: Arial, Helvetica, sans-serif; font-size: 18px; font-weight: bold; color: #ffffff; text-transform: uppercase;">
                                                            DOESN'T SUPPORT
                                                        </span>
                                                    </td>
                                                </tr>

                                                <!-- Neighbor 1 -->
                                                <tr>
                                                    <td style="background-color: #ffffff; padding: 14px 35px; border-bottom: 1px solid #e5e7eb;">
                                                        <p style="margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; font-weight: bold; color: #1f2937;">
                                                            Sarah Mitchell
                                                        </p>
                                                    </td>
                                                    <td style="background-color: #16a34a; padding: 14px 35px; border-bottom: 1px solid #e5e7eb; text-align: center;">
                                                        <span style="font-family: Arial, Helvetica, sans-serif; font-size: 16px; font-weight: bold; color: #ffffff; text-transform: uppercase;">
                                                            SUPPORTS
                                                        </span>
                                                    </td>
                                                </tr>

                                                <!-- Neighbor 2 -->
                                                <tr>
                                                    <td style="background-color: #f9fafb; padding: 14px 35px; border-bottom: 1px solid #e5e7eb;">
                                                        <p style="margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; font-weight: bold; color: #1f2937;">
                                                            Marcus Rodriguez
                                                        </p>
                                                    </td>
                                                    <td style="background-color: #16a34a; padding: 14px 35px; border-bottom: 1px solid #e5e7eb; text-align: center;">
                                                        <span style="font-family: Arial, Helvetica, sans-serif; font-size: 16px; font-weight: bold; color: #ffffff; text-transform: uppercase;">
                                                            SUPPORTS
                                                        </span>
                                                    </td>
                                                </tr>

                                                <!-- Neighbor 3 -->
                                                <tr>
                                                    <td style="background-color: #ffffff; padding: 14px 35px;">
                                                        <p style="margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; font-weight: bold; color: #1f2937;">
                                                            Jennifer Chen
                                                        </p>
                                                    </td>
                                                    <td style="background-color: #16a34a; padding: 14px 35px; text-align: center;">
                                                        <span style="font-family: Arial, Helvetica, sans-serif; font-size: 16px; font-weight: bold; color: #ffffff; text-transform: uppercase;">
                                                            SUPPORTS
                                                        </span>
                                                    </td>
                                                </tr>
                                            </table>

                                            <!-- Call to Action -->
                                            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                                                <tr>
                                                    <td align="center" style="padding-top: 20px;">
                                                        <table role="presentation" cellspacing="0" cellpadding="0" border="0">
                                                            <tr>
                                                                <td style="background-color: #f59e0b; border-radius: 6px; padding: 18px 40px; border: 2px solid #d97706;">
                                                                    <span style="font-family: Arial, Helvetica, sans-serif; font-size: 18px; font-weight: bold; color: #ffffff; text-decoration: none; text-transform: uppercase;">
                                                                        UPDATE YOUR STATUS
                                                                    </span>
                                                                </td>
                                                            </tr>
                                                        </table>
                                                    </td>
                                                </tr>
                                            </table>

                                        </td>
                                    </tr>
                                </table>

                            </a>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</body>
</html>
