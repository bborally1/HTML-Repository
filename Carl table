<table style="width:100%; max-width:600px; margin:30px auto; border-collapse:collapse; font-family:Arial, sans-serif; box-shadow: 0 0 6px rgba(0,0,0,0.1);">
  <thead>
    <tr style="background-color:#cc0000; color:#ffffff;">
