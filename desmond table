
<div style="font-family: Arial, Helvetica, sans-serif; max-width: 620px; margin: 0 auto; padding: 1rem 0;">

  <!-- TOP ALERT BANNER -->
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="border-collapse:collapse; max-width:620px; margin-bottom:0;">
    <tr>
      <td style="background:#7F1D1D; padding:10px 24px; border-radius:8px 8px 0 0; text-align:center;">
        <p style="margin:0; color:#FCA5A5; font-size:11px; font-weight:bold; letter-spacing:2px; text-transform:uppercase;">⚠ &nbsp; Action Required — Membership Unclaimed &nbsp; ⚠</p>
      </td>
    </tr>
  </table>

  <!-- HEADER -->
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="border-collapse:collapse; max-width:620px;">
    <tr>
      <td style="background:#B91C1C; padding:22px 28px 18px;">
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
          <tr>
            <td>
              <p style="margin:0 0 2px; color:rgba(255,255,255,0.7); font-size:11px; letter-spacing:1.5px; text-transform:uppercase; font-weight:bold;">Official Supporter File</p>
              <p style="margin:0; color:#ffffff; font-size:22px; font-weight:bold; line-height:1.2;">MAGA Membership Record</p>
              <p style="margin:6px 0 0; color:rgba(255,255,255,0.8); font-size:13px;">${Recipient.FIRST_NAME} — your membership is waiting</p>
            </td>
            <td align="right" valign="top">
              <table cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="background:rgba(255,255,255,0.12); border:1px solid rgba(255,255,255,0.25); border-radius:6px; padding:8px 14px; text-align:center;">
                    <p style="margin:0; color:#FCA5A5; font-size:10px; font-weight:bold; letter-spacing:1px; text-transform:uppercase;">Status</p>
                    <p style="margin:3px 0 0; color:#ffffff; font-size:13px; font-weight:bold;">UNCLAIMED</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  <!-- SUPPORTER INFO BLOCK -->
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="border-collapse:collapse; max-width:620px;">
    <tr>
      <td style="background:#1F2937; padding:14px 28px;">
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
          <tr>
            <td style="width:50%; padding-right:16px;">
              <p style="margin:0; color:#9CA3AF; font-size:10px; font-weight:bold; letter-spacing:1px; text-transform:uppercase;">Supporter</p>
              <p style="margin:3px 0 0; color:#F9FAFB; font-size:14px; font-weight:bold;">${Recipient.FIRST_NAME}</p>
            </td>
            <td style="width:50%;">
              <p style="margin:0; color:#9CA3AF; font-size:10px; font-weight:bold; letter-spacing:1px; text-transform:uppercase;">Location</p>
              <p style="margin:3px 0 0; color:#F9FAFB; font-size:14px; font-weight:bold;">${Recipient.STATE} &nbsp;${Recipient.ZIP}</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  <!-- MAIN TABLE -->
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="border-collapse:collapse; max-width:620px; border:1px solid #E5E7EB; border-top:none;">

    <!-- Col headers -->
    <tr style="background:#F3F4F6;">
      <td style="padding:10px 28px; border-bottom:1px solid #E5E7EB; width:44%;">
        <p style="margin:0; font-size:10px; color:#9CA3AF; font-weight:bold; text-transform:uppercase; letter-spacing:1px;">Field</p>
      </td>
      <td style="padding:10px 20px; border-bottom:1px solid #E5E7EB;">
        <p style="margin:0; font-size:10px; color:#9CA3AF; font-weight:bold; text-transform:uppercase; letter-spacing:1px;">On File</p>
      </td>
      <td style="padding:10px 20px; border-bottom:1px solid #E5E7EB; text-align:center;">
        <p style="margin:0; font-size:10px; color:#9CA3AF; font-weight:bold; text-transform:uppercase; letter-spacing:1px;">Status</p>
      </td>
    </tr>

    <!-- Email row -->
    <tr style="background:#ffffff;">
      <td style="padding:13px 28px; border-bottom:1px solid #F3F4F6;">
        <p style="margin:0; font-size:12px; color:#6B7280; font-weight:bold; text-transform:uppercase; letter-spacing:0.5px;">Email</p>
      </td>
      <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6;">
        <p style="margin:0; font-size:13px; color:#111827;">${Recipient.EMAIL}</p>
      </td>
      <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; text-align:center;">
        <span style="display:inline-block; background:#D1FAE5; color:#065F46; font-size:10px; font-weight:bold; padding:3px 10px; border-radius:20px; text-transform:uppercase; letter-spacing:0.5px;">✓ Verified</span>
      </td>
    </tr>


    <!-- State row -->
    <tr style="background:#ffffff;">
      <td style="padding:13px 28px; border-bottom:1px solid #F3F4F6;">
        <p style="margin:0; font-size:12px; color:#6B7280; font-weight:bold; text-transform:uppercase; letter-spacing:0.5px;">State</p>
      </td>
      <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6;">
        <p style="margin:0; font-size:13px; color:#111827;">${Recipient.STATE}</p>
      </td>
      <td style="padding:13px 20px; border-bottom:1px solid #F3F4F6; text-align:center;">
        <span style="display:inline-block; background:#D1FAE5; color:#065F46; font-size:10px; font-weight:bold; padding:3px 10px; border-radius:20px; text-transform:uppercase; letter-spacing:0.5px;">✓ Confirmed</span>
      </td>
    </tr>

    <!-- MAGA Membership row — highlighted -->
    <tr style="background:#FEF2F2;">
      <td style="padding:15px 28px; border-bottom:none; border-left:4px solid #B91C1C;">
        <p style="margin:0; font-size:12px; color:#991B1B; font-weight:bold; text-transform:uppercase; letter-spacing:0.5px;">MAGA Membership</p>
      </td>
      <td style="padding:15px 20px; border-bottom:none;">
        <p style="margin:0; font-size:13px; color:#991B1B; font-weight:bold;">Not Yet Activated</p>
      </td>
      <td style="padding:15px 20px; border-bottom:none; text-align:center;">
        <span style="display:inline-block; background:#B91C1C; color:#ffffff; font-size:10px; font-weight:bold; padding:3px 12px; border-radius:20px; text-transform:uppercase; letter-spacing:0.8px;">⚠ UNCLAIMED</span>
      </td>
    </tr>

  </table>

  <!-- CTA FOOTER -->
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="border-collapse:collapse; max-width:620px; background:#111827; border-radius:0 0 8px 8px;">
    <tr>
      <td style="padding:24px 28px; text-align:center;">
        <p style="margin:0 0 4px; color:#F9FAFB; font-size:15px; font-weight:bold;">${Recipient.FIRST_NAME}, your membership card is waiting.</p>
     
        <a href="SupporterStatus${Recipient.FIRST_NAME}"
           style="display:inline-block; background:#B91C1C; color:#ffffff; font-size:14px; font-weight:bold; padding:14px 36px; border-radius:6px; text-decoration:none; text-transform:uppercase; letter-spacing:1.2px;">
          ✔ &nbsp; Fix Now — Claim My Membership
        </a>

      </td>
    </tr>
  </table>

</div>
