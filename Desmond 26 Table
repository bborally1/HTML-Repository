<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Platinum Status Confirmation</title>
</head>
<body style="margin: 0; padding: 0; font-family: Arial, Helvetica, sans-serif; background-color: #fff;">
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #ffff;">
        <tr>
            <td style="padding: 30px 15px;">
                
                <!-- Main Card -->
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="max-width: 600px; margin: 0 auto; background: linear-gradient(135deg, #ffffff 0%, #f9f9f9 100%); border-radius: 12px; box-shadow: 0 6px 20px rgba(0,0,0,0.12); border: 2px solid #d0d0d0;">
                    
                    <!-- Logo Section -->
                    <tr>
                        <td style="padding: 30px 20px 20px; text-align: center;">
                            <img src="https://www.myimgcloud.com/a7b37ba8-c89f-4e02-b709-cfee6f50cb83.png" 
                                 alt="Platinum Logo" 
                                 style="display: inline-block; max-width: 100px; height: auto;">
                        </td>
                    </tr>
                    
                    <!-- Header Section -->
                    <tr>
                        <td style="padding: 25px 25px 20px; text-align: center; background: linear-gradient(135deg, #fafafa 0%, #f0f0f0 100%); border-top: 2px solid #d5d5d5; border-bottom: 2px solid #d5d5d5;">
                            <h2 style="margin: 0 0 10px; font-size: 24px; line-height: 1.3; color: #333; font-weight: bold; letter-spacing: 0.3px;">
                                ⚠️ GOP Round Table Participation: <span style="color: #d32f2f; background: linear-gradient(135deg, #ff5252 0%, #d32f2f 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Unconfirmed</span>
                            </h2>
                            <p style="margin: 0; font-size: 15px; color: #666; line-height: 1.5;">
                                Hi <strong style="color: #d32f2f; font-size: 17px; background-color: #ffebee; padding: 3px 10px; border-radius: 5px;">${Recipient.FIRST_NAME}</strong>, action required to finalize your membership
                            </p>
                        </td>
                    </tr>
                    
                    <!-- Content Section -->
                    <tr>
                        <td style="padding: 30px 30px 25px; color: #333; line-height: 1.7; font-size: 15px;">
                            <p style="margin: 0 0 18px; font-size: 16px;">
                                <strong>${Recipient.FIRST_NAME}</strong>, since you have been identified as a TOP 2% supporter has been your spot has been <strong style="color: #333; background: linear-gradient(135deg, #fff9c4 0%, #ffeb3b 100%); padding: 2px 6px; border-radius: 3px;">pre-approved</strong>, but you NEED to claim it.
                            </p>
                            
                        
                    
                    <!-- CTA Button Section -->
                    <tr>
                        <td style="padding: 25px 30px 35px; text-align: center; background: linear-gradient(135deg, #fafafa 0%, #f5f5f5 100%); border-top: 2px solid #e0e0e0; border-radius: 0 0 12px 12px;">
                            <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin: 0 auto;">
                                <tr>
                                    <td style="border-radius: 8px; background: linear-gradient(135deg, #e53935 0%, #b71c1c 100%); box-shadow: 0 5px 16px rgba(229, 57, 53, 0.35);">
                                        <a href="LINK" target="_blank" style="display: inline-block; padding: 16px 36px; font-family: Arial, Helvetica, sans-serif; font-size: 17px; font-weight: bold; color: #ffffff; text-decoration: none; border-radius: 8px; letter-spacing: 0.5px; min-width: 260px; text-align: center;">
                                            ✅ CONFIRM YOUR SPOT NOW
                                        </a>
                                    </td>
                                </tr>
                            </table>
                            <p style="margin: 15px 0 0; font-size: 13px; color: #888; line-height: 1.4;">
                                Confirmation expires soon • Secure your access now
                            </p>
                        </td>
                    </tr>
                    
                </table>
                
            </td>
        </tr>
    </table>
</body>
</html>
