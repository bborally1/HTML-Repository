<table cellpadding="0" cellspacing="0" border="0" style="width: 600px; max-width: 100%; margin: 0 auto; background: linear-gradient(135deg, #4a5d23 0%, #2d3436 50%, #1e2124 100%); border: 3px solid #74b816; box-shadow: 0 0 20px rgba(116, 184, 22, 0.3); font-family: 'Courier New', monospace;">
        
        <!-- Header -->
        <tr>
            <td colspan="2" style="background: linear-gradient(90deg, #74b816 0%, #4a5d23 100%); padding: 15px; text-align: center; border-bottom: 2px solid #2d3436;">
                <div style="color: #000000; font-size: 24px; font-weight: bold; letter-spacing: 3px; text-shadow: 1px 1px 2px rgba(0,0,0,0.3);">
                    ⚡ SECURE MISSION DETAILS ⚡
                </div>
            </td>
        </tr>
        
        <!-- Mission Assignment -->
        <tr>
            <td colspan="2" style="background-color: #2d3436; padding: 20px; border-bottom: 1px solid #4a5d23;">
                <div style="color: #ffffff; font-size: 16px; margin-bottom: 10px;">
                    <span style="color: #74b816; font-weight: bold;">MISSION ASSIGNED TO:</span> 
                    <span style="color: #ffeaa7;">${Recipient.FIRST_NAME}</span>
                </div>
                <div style="background-color: #fdcb6e; color: #2d3436; padding: 12px; font-weight: bold; font-size: 18px; text-align: center; border-left: 4px solid #e17055; margin: 10px 0;">
                    🎯 HELP NAVY SEAL REP. ZINKE REACH HIS END OF MONTH GOAL
                </div>
            </td>
        </tr>
        
        <!-- Mission Details Grid -->
        <tr>
            <td style="width: 50%; background-color: #1e2124; padding: 20px; border-right: 1px solid #4a5d23; border-bottom: 1px solid #4a5d23;">
                <div style="color: #74b816; font-size: 14px; font-weight: bold; margin-bottom: 8px; letter-spacing: 1px;">
                    📅 MISSION DUE:
                </div>
                <div style="background-color: #d63031; color: #ffffff; padding: 10px; text-align: center; font-weight: bold; font-size: 16px; border-radius: 3px;">
                    ASAP
                </div>
            </td>
            <td style="width: 50%; background-color: #1e2124; padding: 20px; border-bottom: 1px solid #4a5d23;">
                <div style="color: #74b816; font-size: 14px; font-weight: bold; margin-bottom: 8px; letter-spacing: 1px;">
                    💰 AMOUNT NEEDED:
                </div>
                <div style="background-color: #fdcb6e; color: #2d3436; padding: 10px; text-align: center; font-weight: bold; font-size: 18px; border-radius: 3px;">
                    $30
                </div>
            </td>
        </tr>
        
        <!-- Status Section -->
        <tr>
            <td colspan="2" style="background-color: #2d3436; padding: 20px; text-align: center;">
                <div style="color: #74b816; font-size: 16px; font-weight: bold; margin-bottom: 15px; letter-spacing: 2px;">
                    📊 CURRENT STATUS:
                </div>
                <div style="background-color: #d63031; color: #ffffff; padding: 12px; font-weight: bold; font-size: 18px; margin-bottom: 20px; border-radius: 3px; letter-spacing: 1px;">
                    ⚠️ INCOMPLETE ⚠️
                </div>
                
                <!-- Call to Action Button -->
                <div style="background: linear-gradient(45deg, #74b816 0%, #4a5d23 100%); padding: 15px 30px; color: #ffffff; font-weight: bold; font-size: 18px; text-align: center; border-radius: 5px; border: 2px solid #2d3436; box-shadow: 0 4px 8px rgba(0,0,0,0.3); letter-spacing: 1px;">
                    🚀 COMPLETE YOUR MISSION HERE &gt;&gt;
                </div>
            </td>
        </tr>
        
        <!-- Footer Bar -->
        <tr>
            <td colspan="2" style="background: linear-gradient(90deg, #2d3436 0%, #74b816 50%, #2d3436 100%); padding: 10px; text-align: center;">
                <div style="color: #ffffff; font-size: 12px; letter-spacing: 2px;">
                    ★ CLASSIFIED - FOR AUTHORIZED PERSONNEL ONLY ★
                </div>
            </td>
        </tr>
        
</table>
