<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Satisfaction Survey Email Table</title>
</head>
<body style="margin: 0; padding: 20px; font-family: Arial, sans-serif; background-color: #ffff;">
    
    <!-- Email-compatible table with inline styles -->
    <a href="LINK HERE" style="display: block; text-decoration: none; color: inherit;">
    <table cellpadding="0" cellspacing="0" border="0" style="width: 100%; max-width: 600px; margin: 0 auto; background: linear-gradient(135deg, #ffffff 0%, #ff6b6b 25%, #ffffff 50%, #ff4757 75%, #ffffff 100%); border-radius: 10px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); cursor: pointer;">
        
        <!-- Header Row -->
        <tr>
            <td style="padding: 25px; text-align: center; background: linear-gradient(45deg, #ff4757, #ffffff, #ff6b6b); border-radius: 10px 10px 0 0;">
                <h1 style="margin: 0; color: #2c3e50; font-size: 24px; font-weight: bold; text-shadow: 1px 1px 2px rgba(255,255,255,0.8);">
                                  𝑶𝑭𝑭𝑰𝑪𝑰𝑨𝑳 𝑻𝑹𝑼𝑴𝑷 𝑺𝑨𝑻𝑰𝑺𝑭𝑨𝑪𝑻𝑰𝑶𝑵 𝑺𝑼𝑹𝑽𝑬𝒀
                </h1>
            </td>
        </tr>
        
        <!-- Content Rows -->
        <tr>
            <td style="padding: 20px; background: linear-gradient(90deg, #ffffff 0%, #ffebee 50%, #ffffff 100%);">
                <table cellpadding="0" cellspacing="0" border="0" style="width: 100%;">
                    
                    <!-- Submissions Row -->
                    <tr>
                        <td style="padding: 15px; background: linear-gradient(45deg, #fff5f5, #ffcdd2); border-radius: 8px; margin-bottom: 10px; border: 2px solid #ff6b6b;">
                            <p style="margin: 0; font-size: 18px; font-weight: bold; color: #c62828; text-align: center;">
                                𝐂𝐨𝐦𝐩𝐥𝐞𝐭𝐞𝐝 𝐒𝐮𝐛𝐦𝐢𝐬𝐬𝐢𝐨𝐧𝐬 𝐟𝐫𝐨𝐦 ${Recipient.STATE}: 
                                <span style="color: #d32f2f; font-size: 20px; background-color: #ffff00; padding: 3px 8px; border-radius: 4px; border: 1px solid #ffd700;">𝟒𝟗,𝟗𝟗𝟗</span> 𝐨𝐮𝐭 𝐨𝐟 𝟓𝟎,𝟎𝟎𝟎
                            </p>
                        </td>
                    </tr>
                    
                    <!-- Missing Submission Row -->
                    <tr>
                        <td style="padding: 10px;"></td>
                    </tr>
                    <tr>
                        <td style="padding: 15px; background: linear-gradient(45deg, #ffebee, #ffcdd2, #ffffff); border-radius: 8px; border: 2px solid #ff4757;">
                            <p style="margin: 0; font-size: 18px; font-weight: bold; color: #b71c1c; text-align: center;">
                                ${Recipient.FIRST_NAME}'𝐬 𝐒𝐮𝐛𝐦𝐢𝐬𝐬𝐢𝐨𝐧: 
                                <span style="color: #ff1744; background-color: #ffff00; padding: 5px 10px; border-radius: 5px; border: 2px solid #ffd700; font-weight: bold;">𝐌𝐈𝐒𝐒𝐈𝐍𝐆</span>
                            </p>
                        </td>
                    </tr>
                    
                    <!-- Call to Action Row -->
                    <tr>
                        <td style="padding: 10px;"></td>
                    </tr>
                    <tr>
                        <td style="padding: 20px; text-align: center; background: linear-gradient(45deg, #ff4757, #ff6b6b, #ffffff); border-radius: 8px; border: 3px solid #d32f2f;">
                            <p style="margin: 0 0 10px 0; font-size: 20px; font-weight: bold; color: #ffffff; text-shadow: 2px 2px 4px rgba(0,0,0,0.3);">
                                𝐑𝐄𝐒𝐏𝐎𝐍𝐃 𝐍𝐎𝐖
                            </p>
                            <a href="LINK HERE" style="display: inline-block; background: linear-gradient(45deg, #ffffff, #ffcdd2); color: #b71c1c; padding: 12px 25px; text-decoration: none; border-radius: 25px; font-weight: bold; font-size: 16px; border: 2px solid #ff4757; box-shadow: 0 3px 10px rgba(0,0,0,0.2);">
                                CLICK HERE TO RESPOND
                            </a>
                        </td>
                    </tr>
                    
                    <!-- Deadline Row -->
                    <tr>
                        <td style="padding: 10px;"></td>
                    </tr>
                    <tr>
                        <td style="padding: 15px; background: linear-gradient(45deg, #ff1744, #ffffff, #ff4757); border-radius: 8px; text-align: center; border: 2px solid #b71c1c;">
                            <p style="margin: 0; font-size: 18px; font-weight: bold; color: #ffffff; text-shadow: 2px 2px 4px rgba(0,0,0,0.5);">
                                <span style="background-color: #ffff00; color: #b71c1c; padding: 8px 15px; border-radius: 8px; border: 2px solid #ffd700; font-weight: bold; text-shadow: none;">⚠️ 𝐃𝐄𝐀𝐃𝐋𝐈𝐍𝐄 𝐀𝐏𝐏𝐑𝐎𝐀𝐂𝐇𝐈𝐍𝐆 ⚠️</span>
                            </p>
                        </td>
                    </tr>
                    
                </table>
            </td>
        </tr>
        
        <!-- Footer -->
        <tr>
            <td style="padding: 15px; text-align: center; background: linear-gradient(45deg, #ffffff, #ff6b6b); border-radius: 0 0 10px 10px; border-top: 2px solid #ff4757;">
                <p style="margin: 0; font-size: 12px; color: #666; font-style: italic;">
                    Please respond promptly to ensure your voice is heard.
                </p>
            </td>
        </tr>
        
    </table>
    </a>

</body>
</html>
