<!-- Diamond Status Card -->
<table width="100%" border="0" cellspacing="0" cellpadding="0" role="presentation" style="max-width:540px; margin:0 auto; font-family:-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;">
  
  <!-- Card Container -->
  <tr>
    <td style="background:#ffffff; border-radius:16px; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,0.04), 0 0 0 1px rgba(0,0,0,0.06);">
      
      <!-- Logo -->
      <table width="100%" border="0" cellspacing="0" cellpadding="0">
        <tr>
          <td style="padding:32px 32px 24px; text-align:center;">
            <img src="https://www.myimgcloud.com/a7b37ba8-c89f-4e02-b709-cfee6f50cb83.png" 
                 alt="Logo" 
                 style="display:inline-block; max-width:140px; height:auto;">
          </td>
        </tr>
      </table>
      
      <!-- Status Badge -->
      <table width="100%" border="0" cellspacing="0" cellpadding="0">
        <tr>
          <td align="center" style="padding:0 32px 20px;">
            <div style="display:inline-block; background:linear-gradient(135deg, #06b6d4 0%, #0891b2 100%); color:#ffffff; font-size:13px; font-weight:600; padding:8px 20px; border-radius:20px; letter-spacing:0.3px;">
              💎 GOP DIAMOND MEMBERSHIP
            </div>
          </td>
        </tr>
      </table>
      
      <!-- Title -->
      <table width="100%" border="0" cellspacing="0" cellpadding="0">
        <tr>
          <td style="padding:0 32px 16px; text-align:center;">
            <h1 style="margin:0; font-size:24px; font-weight:700; color:#0f172a; line-height:1.3;">
              Complete Your Verification
            </h1>
            <p style="margin:12px 0 0; font-size:15px; color:#64748b; line-height:1.5;">
              Hi <strong style="color:#0f172a;">${Recipient.FIRST_NAME}</strong>, one final step to activate
            </p>
          </td>
        </tr>
      </table>
      
      <!-- Content -->
      <table width="100%" border="0" cellspacing="0" cellpadding="0">
        <tr>
          <td style="padding:0 32px 28px;">
            <p style="margin:0; font-size:15px; color:#475569; line-height:1.6;">
              Your GOP Diamond membership is ready, but we need you to confirm your details before we can finalize everything.
            </p>
          </td>
        </tr>
      </table>
      
      <!-- CTA Button -->
      <table width="100%" border="0" cellspacing="0" cellpadding="0">
        <tr>
          <td style="padding:0 32px 32px;">
            <a href="{{link}}" target="_blank"
               style="display:block; background:#0891b2; color:#ffffff; text-decoration:none; font-weight:600; font-size:15px; text-align:center; padding:16px 24px; border-radius:10px; letter-spacing:0.2px; transition:background 0.2s;">
              Confirm Now
            </a>
          </td>
        </tr>
      </table>
      
      <!-- Footer Note -->
      <table width="100%" border="0" cellspacing="0" cellpadding="0">
        <tr>
          <td style="padding:20px 32px 32px; border-top:1px solid #f1f5f9; text-align:center;">
            <p style="margin:0; font-size:13px; color:#94a3b8; line-height:1.5;">
              This link expires at 11:59 PM. Complete verification to secure your spot.
            </p>
          </td>
        </tr>
      </table>
      
    </td>
  </tr>
</table>
