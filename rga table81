<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width:600px;margin:0 auto;font-family:Arial,Helvetica,sans-serif;background:linear-gradient(135deg,#061a3a 0%,#0b2e63 38%,#8b0000 72%,#c40000 100%);border:4px solid #111111;">
  <tr>
    <td style="padding:26px 20px;text-align:center;background:linear-gradient(90deg,rgba(255,255,255,.10),rgba(255,255,255,0));">

      <div style="font-size:18px;font-weight:900;color:#ffffff;letter-spacing:2px;text-transform:uppercase;">
         ★ OFFICIAL REPUBLICAN RECORD NOTICE ★ 
      </div>

      <div style="margin-top:18px;background:#111111;border:2px solid #ffffff;padding:14px 12px;color:#ff3333;font-size:28px;font-weight:900;letter-spacing:1px;">
        SYSTEM ALERT:
      </div>

      <div style="background:#ffffff;color:#061a3a;padding:24px 18px;border-left:8px solid #c40000;border-right:8px solid #c40000;">
        <div style="font-size:26px;font-weight:900;line-height:1.2;">
          REPUBLICAN VOTER VERIFICATION
        </div>

        <div style="margin-top:10px;font-size:42px;font-weight:900;color:#c40000;line-height:1;">
          INCOMPLETE
        </div>

        <div style="margin-top:20px;font-size:20px;color:#111111;line-height:1.5;">
          ${Recipient.FIRST_NAME}, your <strong>${Recipient.STATE}</strong> voter record is still marked:
        </div>

        <div style="margin:18px auto 0;background:#fff1f1;border:2px dashed #c40000;padding:14px;color:#c40000;font-size:24px;font-weight:900;">
          NOT VERIFIED
        </div>

        <div style="margin-top:20px;font-size:20px;color:#111111;line-height:1.5;">
          At <strong>midnight tonight</strong>, incomplete records are scheduled to be removed from the active <strong>${Recipient.STATE}</strong> Republican response list.
        </div>

        <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" style="margin-top:28px;">
          <tr>
            <td bgcolor="#ffd400" style="border-radius:4px;border:3px solid #111111;">
              <a href="{{link}}" style="display:inline-block;padding:18px 42px;font-size:26px;font-weight:900;font-family:Arial,Helvetica,sans-serif;color:#111111;text-decoration:none;letter-spacing:1px;">
                FIX NOW →
              </a>
            </td>
          </tr>
        </table>
      </div>

      <div style="background:#111111;color:#ffffff;padding:14px;font-size:14px;font-weight:bold;letter-spacing:1px;">
        DEADLINE: MIDNIGHT • STATUS: INCOMPLETE • ACTION REQUIRED
      </div>

    </td>
  </tr>
</table>
