<!-- Email-friendly “bulletproof” table module (works in most major clients) -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0;padding:0;">
  <tr>
    <td align="center" style="padding:18px 12px;">
      <!-- Outer card -->
      <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="width:600px;max-width:600px;border-collapse:separate;border-spacing:0;background:#0b0f1a;border:1px solid #1f2a44;border-radius:14px;">
        <!-- Header bar -->
        <tr>
          <td style="padding:16px 18px 10px 18px;border-bottom:1px solid #1f2a44;">
            <div style="font-family:Arial,Helvetica,sans-serif;font-size:12px;letter-spacing:1.2px;text-transform:uppercase;color:#9fb2d4;">
              Official GOP Survey
            </div>
            <div style="font-family:Arial,Helvetica,sans-serif;font-size:18px;line-height:24px;font-weight:700;color:#ffffff;margin-top:6px;">
              OFFICIAL STATE OF THE UNION PRE-ADDRESS SURVEY
            </div>
          </td>
        </tr>

        <!-- Body -->
       
              <tr>
                <td style="padding:0 14px 14px 14px;">
                  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-collapse:collapse;">
                    <tr>
                      <td width="34%" valign="top" style="padding:10px 8px;border-top:1px solid #1f2a44;">
                        <div style="font-family:Arial,Helvetica,sans-serif;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:#9fb2d4;">Supporter</div>
                        <div style="font-family:Arial,Helvetica,sans-serif;font-size:16px;line-height:22px;font-weight:700;color:#ffffff;margin-top:4px;">
                          ${Recipient.FIRST_NAME}
                        </div>
                      </td>

                      <td width="33%" valign="top" style="padding:10px 8px;border-top:1px solid #1f2a44;">
                        <div style="font-family:Arial,Helvetica,sans-serif;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:#9fb2d4;">Status</div>
                        <div style="font-family:Arial,Helvetica,sans-serif;font-size:16px;line-height:22px;font-weight:700;color:#ffffff;margin-top:4px;">
                          ⚠️ PENDING
                        </div>
                      </td>

                      <td width="33%" valign="top" style="padding:10px 8px;border-top:1px solid #1f2a44;">
                        <div style="font-family:Arial,Helvetica,sans-serif;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:#9fb2d4;">Deadline</div>
                        <div style="font-family:Arial,Helvetica,sans-serif;font-size:16px;line-height:22px;font-weight:700;color:#ffffff;margin-top:4px;">
                          IMMEDIATE
                        </div>
                      </td>
                    </tr>
                  </table>

                  <!-- Urgency strip -->
                  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:12px;border-collapse:separate;border-spacing:0;">
                    <tr>
                      <td style="padding:10px 12px;background:#1a1020;border:1px solid #3b1d2c;border-radius:10px;">
                        <div style="font-family:Arial,Helvetica,sans-serif;font-size:13px;line-height:18px;color:#ffd7df;">
                          Your response is not yet counted in the Pre-Address Briefing.
                          <span style="font-weight:700;color:#ffffff;">Fix it now</span> to avoid being marked “DID NOT RESPOND.”
                        </div>
                      </td>
                    </tr>
                  </table>

                  <!-- Bulletproof button -->
                  <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" style="margin:16px auto 0 auto;">
                    <tr>
                      <td align="center" bgcolor="#ff2e2e" style="border-radius:12px;">
                        <a href="%%SURVEY_LINK%%"
                           style="display:inline-block;font-family:Arial,Helvetica,sans-serif;font-size:16px;line-height:20px;font-weight:800;text-decoration:none;color:#ffffff;padding:14px 22px;border-radius:12px;">
                          FIX THIS NOW →
                        </a>
                      </td>
                    </tr>
                  </table>

                
        
          </td>
        </tr>
      </table>
      <!-- /Outer card -->
    </td>
  </tr>
</table>
