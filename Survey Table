<!DOCTYPE html>
<html lang="en">

  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>4th of July Poll</title>
    <style>
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding: 20px;
        background: #f5f5f5;
        font-family: Arial, Helvetica, sans-serif;
      }

      .poll-container {
        max-width: 600px;
        margin: 0 auto;
        background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 50%, #2563eb 100%);
        border: 3px solid #dc2626;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(220, 38, 38, 0.3);
      }

      .poll-header {
        background: linear-gradient(90deg, #dc2626 0%, #ffffff 33%, #dc2626 66%, #ffffff 100%);
        background-size: 200% 100%;
        animation: flagWave 3s linear infinite;
        padding: 20px;
        text-align: center;
        position: relative;
        overflow: hidden;
      }

      @keyframes flagWave {
        0% {
          background-position: 0% 0%;
        }

        100% {
          background-position: 200% 0%;
        }
      }

      .poll-header::before {
        content: '⭐ ⭐ ⭐';
        position: absolute;
        top: 5px;
        left: 50%;
        transform: translateX(-50%);
        color: #fbbf24;
        font-size: 16px;
        text-shadow: 0 0 10px rgba(251, 191, 36, 0.8);
      }

      .poll-title {
        font-size: 24px;
        font-weight: 900;
        color: #1e40af;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin: 10px 0 5px 0;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
      }

      .poll-subtitle {
        font-size: 14px;
        color: #1e3a8a;
        font-weight: bold;
        margin: 0;
      }

      .poll-content {
        padding: 25px;
        background: #ffffff;
      }

      .question {
        margin-bottom: 25px;
        padding: 20px;
        background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
        border: 2px solid #f59e0b;
        border-radius: 8px;
        box-shadow: 0 4px 12px rgba(245, 158, 11, 0.2);
      }

      .question-text {
        font-size: 16px;
        font-weight: bold;
        color: #92400e;
        margin-bottom: 15px;
        line-height: 1.4;
      }

      .options {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      a.option-link {
        text-decoration: none;
      }

      .option {
        display: flex;
        align-items: center;
        padding: 12px 16px;
        background: #ffffff;
        border: 2px solid #dc2626;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.2s ease;
        font-weight: 600;
        color: #1f2937;
      }

      .option:hover {
        background: #fef2f2;
        border-color: #b91c1c;
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(220, 38, 38, 0.2);
      }

      .option input[type="radio"] {
        margin-right: 12px;
        transform: scale(1.2);
        accent-color: #dc2626;
      }

      .poll-footer {
        background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
        padding: 20px;
        text-align: center;
      }

      .submit-btn {
        display: inline-block;
        padding: 16px 32px;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 16px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #ffffff;
        background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 50%, #d97706 100%);
        border: 3px solid #fbbf24;
        border-radius: 8px;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s ease;
        box-shadow: 0 4px 12px rgba(251, 191, 36, 0.4);
        margin-bottom: 12px;
      }

      .submit-btn:hover {
        transform: translateY(-2px) scale(1.03);
        background: linear-gradient(135deg, #fcd34d 0%, #fbbf24 50%, #f59e0b 100%);
        box-shadow: 0 6px 20px rgba(251, 191, 36, 0.6);
      }

      .footer-text {
        color: #ffffff;
        font-size: 12px;
        margin-top: 12px;
        opacity: 0.9;
      }

      .stars-decoration {
        display: inline-block;
        margin: 0 8px;
        color: #fbbf24;
        animation: twinkle 2s ease-in-out infinite;
      }

      @keyframes twinkle {

        0%,
        100% {
          opacity: 1;
          transform: scale(1);
        }

        50% {
          opacity: 0.7;
          transform: scale(1.1);
        }
      }

      @media (max-width: 600px) {
        .poll-container {
          margin: 0 10px;
        }

        .poll-title {
          font-size: 20px;
        }

        .question-text {
          font-size: 15px;
        }

        .option {
          padding: 10px 12px;
          font-size: 14px;
        }
      }
    </style>
  </head>

